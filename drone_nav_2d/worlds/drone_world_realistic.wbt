#VRML_SIM R2023b utf8

WorldInfo {
  basicTimeStep 32
}
Viewpoint {
  orientation 0.88 0.26 0.39 1.15
  position -10 -10 7.5
}
TexturedBackground { }
TexturedBackgroundLight { }

DirectionalLight {
  direction -0.4 -0.3 -1
  intensity 2.0
}

Floor {
  translation 0 0 0
  size 24 24
  appearance PBRAppearance {
    baseColor 0.52 0.44 0.30
    roughness 1
    metalness 0
  }
}

# Plain landing-strip style corridor
Solid {
  name "plain_corridor"
  translation 0 0 0.01
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.72 0.72 0.70
        roughness 0.95
        metalness 0
      }
      geometry Box { size 16 3.5 0.02 }
    }
  ]
  boundingObject Box { size 16 3.5 0.02 }
  locked TRUE
}

# Hill zone (rolling terrain)
Solid {
  name "hill_01"
  translation -1.8 4.0 0.55
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.29 0.54 0.22
        roughness 1
      }
      geometry Sphere { radius 1.1 }
    }
  ]
  boundingObject Sphere { radius 1.1 }
  locked TRUE
}

Solid {
  name "hill_02"
  translation 2.8 4.2 0.75
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.30 0.56 0.24
        roughness 1
      }
      geometry Sphere { radius 1.4 }
    }
  ]
  boundingObject Sphere { radius 1.4 }
  locked TRUE
}

Solid {
  name "hill_03"
  translation 6.6 3.8 0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.26 0.50 0.20
        roughness 1
      }
      geometry Sphere { radius 1.0 }
    }
  ]
  boundingObject Sphere { radius 1.0 }
  locked TRUE
}

# Mountain zone (steep terrain)
Solid {
  name "mountain_01"
  translation -2.8 -4.5 1.7
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.43 0.43 0.43
        roughness 0.95
      }
      geometry Cone { bottomRadius 2.0 height 3.4 }
    }
  ]
  boundingObject Cone { bottomRadius 2.0 height 3.4 }
  locked TRUE
}

Solid {
  name "mountain_02"
  translation 2.8 -4.2 1.35
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.46 0.46 0.46
        roughness 0.95
      }
      geometry Cone { bottomRadius 1.6 height 2.7 }
    }
  ]
  boundingObject Cone { bottomRadius 1.6 height 2.7 }
  locked TRUE
}

Solid {
  name "mountain_03"
  translation 6.8 -4.8 2.1
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.38 0.38 0.40
        roughness 0.95
      }
      geometry Cone { bottomRadius 2.2 height 4.2 }
    }
  ]
  boundingObject Cone { bottomRadius 2.2 height 4.2 }
  locked TRUE
}

# Rocks and obstacle blocks (real-world clutter)
Solid {
  translation -1.2 1.2 0.35
  children [ Shape { appearance PBRAppearance { baseColor 0.52 0.50 0.46 } geometry Box { size 0.8 1.2 0.7 } } ]
  boundingObject Box { size 0.8 1.2 0.7 }
  locked TRUE
}
Solid {
  translation 1.4 -1.4 0.4
  children [ Shape { appearance PBRAppearance { baseColor 0.55 0.52 0.48 } geometry Box { size 0.9 1.0 0.8 } } ]
  boundingObject Box { size 0.9 1.0 0.8 }
  locked TRUE
}
Solid {
  translation 3.7 1.0 0.45
  children [ Shape { appearance PBRAppearance { baseColor 0.36 0.22 0.15 } geometry Cylinder { radius 0.55 height 0.9 } } ]
  boundingObject Cylinder { radius 0.55 height 0.9 }
  locked TRUE
}
Solid {
  translation 5.6 -0.8 0.35
  children [ Shape { appearance PBRAppearance { baseColor 0.61 0.58 0.53 } geometry Cylinder { radius 0.45 height 0.7 } } ]
  boundingObject Cylinder { radius 0.45 height 0.7 }
  locked TRUE
}

# Start and goal markers
Solid {
  name "start_marker"
  translation -4 0 0.08
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.05 0.72 0.15 }
      geometry Sphere { radius 0.2 }
    }
  ]
  boundingObject Sphere { radius 0.2 }
  locked TRUE
}

Solid {
  name "goal_marker"
  translation 4 0 0.08
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.95 0.25 0.08 }
      geometry Sphere { radius 0.2 }
    }
  ]
  boundingObject Sphere { radius 0.2 }
  locked TRUE
}

# Realistic-looking quadcopter model
Robot {
  name "drone"
  translation -4 0 0.7
  rotation 0 0 1 0
  controller "<extern>"
  supervisor FALSE
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.14 0.14 0.16
        roughness 0.25
        metalness 0.65
      }
      geometry Cylinder { radius 0.18 height 0.10 }
    }
    Pose {
      translation 0 0 0.08
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 0.05 0.24 0.65
            roughness 0.2
            metalness 0.1
          }
          geometry Sphere { radius 0.09 }
        }
      ]
    }

    Pose {
      translation 0.22 0.22 0.06
      children [
        Shape { appearance PBRAppearance { baseColor 0.10 0.10 0.11 metalness 0.7 roughness 0.25 } geometry Cylinder { radius 0.07 height 0.02 } }
      ]
    }
    Pose {
      translation 0.22 -0.22 0.06
      children [
        Shape { appearance PBRAppearance { baseColor 0.10 0.10 0.11 metalness 0.7 roughness 0.25 } geometry Cylinder { radius 0.07 height 0.02 } }
      ]
    }
    Pose {
      translation -0.22 0.22 0.06
      children [
        Shape { appearance PBRAppearance { baseColor 0.10 0.10 0.11 metalness 0.7 roughness 0.25 } geometry Cylinder { radius 0.07 height 0.02 } }
      ]
    }
    Pose {
      translation -0.22 -0.22 0.06
      children [
        Shape { appearance PBRAppearance { baseColor 0.10 0.10 0.11 metalness 0.7 roughness 0.25 } geometry Cylinder { radius 0.07 height 0.02 } }
      ]
    }

    GPS { name "gps" }
    InertialUnit { name "imu" }
    Lidar {
      name "lidar"
      horizontalResolution 360
      numberOfLayers 1
      fieldOfView 6.283
      minRange 0.05
      maxRange 8.0
      type "fixed"
      translation 0 0 0.10
      rotation 0 1 0 1.5708
    }
  ]
  boundingObject Cylinder { radius 0.30 height 0.14 }
  physics Physics {
    mass 1.25
    density -1
  }
}

# Dynamic obstacle crossing the central plain corridor
Robot {
  name "moving_wall"
  translation 0 0 0
  controller "moving_wall_controller"
  children [
    SliderJoint {
      jointParameters JointParameters {
        axis 0 1 0
      }
      device [
        LinearMotor {
          name "slider_motor"
          maxVelocity 0.8
          minPosition -1.4
          maxPosition 1.4
          position 1.2
        }
        PositionSensor {
          name "slider_sensor"
        }
      ]
      endPoint Solid {
        translation 0 0 0.55
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.82 0.20 0.18 roughness 0.5 metalness 0.2 }
            geometry Box { size 0.45 1.8 1.1 }
          }
        ]
        boundingObject Box { size 0.45 1.8 1.1 }
        physics Physics { mass 0.6 density -1 }
      }
    }
  ]
}
