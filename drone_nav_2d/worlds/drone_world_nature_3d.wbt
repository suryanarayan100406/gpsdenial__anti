# === ROCKS (low obstacles, harder to avoid!) ===
Solid {
  translation -1.5 0 -2.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.45 0.42 0.40
        roughness 0.95
        metalness 0.05
      }
      geometry Sphere { radius 0.5 }
    }
  ]
  name "rock_1"
  boundingObject Sphere { radius 0.5 }
  physics Physics { density 2400 }
}

Solid {
  translation 1.0 0 -1.0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.48 0.44 0.42
        roughness 0.95
        metalness 0.05
      }
      geometry Box { size 0.7 0.4 0.6 }
    }
  ]
  name "rock_2"
  boundingObject Box { size 0.7 0.4 0.6 }
  physics Physics { density 2400 }
}

# === BUSHES / SHRUBS ===
Solid {
  translation -2.0 0 0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.20 0.48 0.15
        roughness 0.95
        metalness 0
      }
      geometry Sphere { radius 0.55 }
    }
  ]
  name "bush_1"
  boundingObject Sphere { radius 0.55 }
  physics Physics { density 350 }
}

Solid {
  translation 1.5 0 3.0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.22 0.44 0.14
        roughness 0.95
        metalness 0
      }
      geometry Sphere { radius 0.45 }
    }
  ]
  name "bush_2"
  boundingObject Sphere { radius 0.45 }
  physics Physics { density 350 }
}

Solid {
  translation -0.5 0 2.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.18 0.46 0.13
        roughness 0.95
      }
      geometry Sphere { radius 0.4 }
    }
  ]
  name "bush_3"
  boundingObject Sphere { radius 0.4 }
  physics Physics { density 350 }
}

# === GOAL MARKER (bright yellow pillar at goal position) ===
Solid {
  translation 4.0 0 -3.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1.0 0.85 0.0
        emissiveColor 0.8 0.6 0.0
        roughness 0.3
        metalness 0.5
      }
      geometry Cylinder { radius 0.08 height 1.5 }
    }
  ]
  name "goal_marker"
}

# === START MARKER (bright cyan pillar at start) ===
Solid {
  translation -4.0 0 0.0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.0 0.85 1.0
        emissiveColor 0.0 0.6 0.8
        roughness 0.3
        metalness 0.5
      }
      geometry Cylinder { radius 0.08 height 1.5 }
    }
  ]
  name "start_marker"
}

# === DRONE ROBOT ===
Robot {
  translation -4.0 1.0 0.0
  rotation 0 1 0 0
  children [
    Receiver { channel 1 type "serial" }
    Emitter { channel 1 type "serial" }
    # Drone body (frame)
    Shape {
      appearance PBRAppearance {
        baseColor 0.10 0.10 0.20
        metalness 0.7
        roughness 0.2
        emissiveColor 0.02 0.02 0.08
      }
      geometry Box { size 0.35 0.10 0.35 }
    }
    # Front-Right arm
    Shape {
      appearance PBRAppearance { baseColor 0.08 0.08 0.18 metalness 0.7 roughness 0.3 }
      geometry Box { size 0.30 0.03 0.04 }
    }
    GPS {
      accuracy 0.1
      translation 0 0.05 0
    }
    Lidar {
      translation 0 0 0
      numberOfLayers 16
      maxRange 8.0
      minRange 0.05
      horizontalResolution 0.05
      verticalFieldOfView 0.8
      noise 0.01
    }
    # Downward-facing camera for top view
    Camera {
      translation 0 -0.08 0
      rotation 1 0 0 -1.5708
      name "downward_camera"
      fieldOfView 1.4
      width 320
      height 240
    }
  ]
  name "drone"
  controller "<extern>"
  selfCollision FALSE
  physics Physics {
    density -1
    mass 1.8
    centerOfMass [ 0 0 0 ]
    inertiaMatrix [ 0.043 0.043 0.064 0 0 0 ]
  }
}
