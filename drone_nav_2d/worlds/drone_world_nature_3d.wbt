Solid {
  translation 4.0 0 1.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.32 0.20 0.09
        roughness 0.85
        metalness 0
      }
      geometry Cylinder { radius 0.15 height 3.0 }
    }
  ]
  name "oak_trunk_2"
  boundingObject Cylinder { radius 0.15 height 3.0 }
  physics Physics { density 700 }
}
Solid {
  translation 4.0 0 3.6
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.10 0.35 0.08
        roughness 0.9
        metalness 0
      }
      geometry Sphere { radius 1.0 }
    }
  ]
  name "oak_canopy_2"
  boundingObject Sphere { radius 1.0 }
  physics Physics { density 250 }
}

# Pine Tree 3 - Far right
Solid {
  translation 3.0 0 -3.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.28 0.16 0.06
        roughness 0.9
      }
      geometry Cylinder { radius 0.13 height 3.0 }
    }
  ]
  name "pine_trunk_3"
  boundingObject Cylinder { radius 0.13 height 3.0 }
  physics Physics { density 600 }
