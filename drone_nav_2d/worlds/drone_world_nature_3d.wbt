#VRML_SIM R2023b utf8
# Realistic Nature 3D World - Forest landscape with clearings
# Top-down view showing drone autonomous navigation through natural terrain

WorldInfo {
  title "GPS-Denied Drone Navigation - Realistic Nature Scene"
  basicTimeStep 8
  coordinateSystem "NUE"
}

# Top-down viewpoint (bird's eye view) - movable in Webots
Viewpoint {
  fieldOfView 1.0
  orientation 1 0 0 -1.5708
  position 0 22 0
  follow "drone"
  followSmoothness 0.2
  followType "Track Position"
}

# Realistic sky background with sun and clouds
TexturedBackground {
  texture "forest"
  luminosity 1.0
}

TexturedBackgroundLight {
  texture "forest"
  castShadows TRUE
}

# Wide grass terrain - 25x25m flat field
Solid {
  translation 0 0 0
  children [
    Shape {
      appearance PBRAppearance {
        baseColorMap ImageTexture {
          url [
            "https://raw.githubusercontent.com/cyberbotics/webots/released/projects/default/worlds/textures/grass.jpg"
          ]
          repeatS 8
          repeatT 8
        }
        roughness 0.95
        metalness 0
        normalMapFactor 0.5
      }
      geometry Plane { size 25 25 }
    }
  ]
  boundingObject Plane { size 25 25 }
  name "terrain"
  locked TRUE
}

# === PINE TREES (arranged as obstacles) ===

# Pine Tree 1 - Left cluster, slightly forward
Solid {
  translation -3.5 0 2.0
  children [
    # Trunk
    Shape {
      appearance PBRAppearance {
        baseColor 0.30 0.18 0.08
        roughness 0.9
        metalness 0
      }
      geometry Cylinder { radius 0.12 height 2.5 }
    }
  ]
  name "pine_trunk_1"
  boundingObject Cylinder { radius 0.12 height 2.5 }
  physics Physics { density 600 }
}
Solid {
  translation -3.5 0 3.2
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.05 0.30 0.08
        roughness 0.9
        metalness 0
      }
      geometry Cone { bottomRadius 1.1 height 2.8 }
    }
  ]
  name "pine_canopy_1"
  boundingObject Cone { bottomRadius 1.1 height 2.8 }
  physics Physics { density 200 }
}

# Pine Tree 2 - Left cluster, behind 1
Solid {
  translation -4.5 0 -0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.28 0.16 0.07
        roughness 0.9
        metalness 0
      }
      geometry Cylinder { radius 0.10 height 2.2 }
    }
  ]
  name "pine_trunk_2"
  boundingObject Cylinder { radius 0.10 height 2.2 }
  physics Physics { density 600 }
}
Solid {
  translation -4.5 0 2.7
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.04 0.25 0.07
        roughness 0.9
        metalness 0
      }
      geometry Cone { bottomRadius 0.9 height 2.4 }
    }
  ]
  name "pine_canopy_2"
  boundingObject Cone { bottomRadius 0.9 height 2.4 }
  physics Physics { density 200 }
}

