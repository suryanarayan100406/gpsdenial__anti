  translation 2.5 0 4.0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.12 0.38 0.09
        roughness 0.9
        metalness 0
      }
      geometry Sphere { radius 1.3 }
    }
  ]
  name "oak_canopy_1"
  boundingObject Sphere { radius 1.3 }
