Solid {
  translation 2.5 0 -1.0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.35 0.22 0.10
        roughness 0.85
        metalness 0
      }
      geometry Cylinder { radius 0.18 height 3.5 }
    }
  ]
  name "oak_trunk_1"
  boundingObject Cylinder { radius 0.18 height 3.5 }
  physics Physics { density 700 }
}
