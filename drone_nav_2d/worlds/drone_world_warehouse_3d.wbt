# Overhead obstructions (beams)
Solid {
  translation 5 -6 8
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.35
        metallic 0.5
        roughness 0.4
      }
      geometry Box { size 0.3 2 0.3 }
    }
  ]
  name "beam_1"
  physics Physics { density 1500 }
}

Solid {
  translation -8 3 7
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.32 0.32 0.37
        metallic 0.5
        roughness 0.4
      }
      geometry Box { size 0.25 3 0.25 }
    }
  ]
  name "beam_2"
  physics Physics { density 1500 }
