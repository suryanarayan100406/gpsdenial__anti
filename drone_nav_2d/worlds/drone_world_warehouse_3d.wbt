# Warehouse lighting (industrial style)
PointLight {
  location -5 5 9
  intensity 0.6
  radius 12
}

PointLight {
  location 5 -3 9
  intensity 0.6
  radius 12
}

# Drone starting near warehouse entrance
Robot {
  translation -15 -18 2
  rotation 0 0 1 0
  children [
    Receiver { channel 1 type "serial" }
    Emitter { channel 1 type "serial" }
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.25 0.3
        metallic 0.4
        roughness 0.3
      }
      geometry Box { size 0.35 0.35 0.1 }
    }
    GPS { accuracy 0.1 }
    Lidar {
      numberOfLayers 6
      maxRange 4
      minRange 0.01
      horizontalResolution 0.12
      verticalFieldOfView 0.45
    }
  ]
  name "drone"
  controller "webots_ros2_driver"
}
