  translation 0 -8 2
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.4 0.4 0.4
        metallic 0.8
        roughness 0.4
      }
      geometry Box { size 0.1 0.4 4 }
    }
  ]
  name "rack_1_post"
  physics Physics { density 1500 }
