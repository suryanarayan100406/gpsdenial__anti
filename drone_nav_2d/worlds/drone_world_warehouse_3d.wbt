#VRML_SIM R2025a utf8
# Warehouse 3D World - Industrial setting with racks
# Large interior space with storage shelves

WorldInfo {
  title "GPS-Denied Warehouse Drone Navigation"
  basicTimeStep 8
  physics "default"
  gravity 0 0 -9.81
}

Viewpoint {
  position 5 -20 5
  orientation 1 0 0 1.57
}

Background {
  skyColor [0.3 0.3 0.35]
  bottomColor [0.2 0.2 0.25]
}

DirectionalLight {
  ambientIntensity 0.6
  direction 1 -0.5 -0.5
  intensity 0.8
  castShadows TRUE
}

# Warehouse floor (concrete)
Solid {
  translation 0 0 0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.35
        metallic 0
        roughness 0.9
      }
      geometry Box { size 50 40 0.2 }
    }
  ]
  name "floor"
  physics Physics { density 2000 }
}

# Ceiling
Solid {
  translation 0 0 10
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.6 0.6 0.65
        metallic 0.3
        roughness 0.5
      }
      geometry Box { size 50 40 0.2 }
    }
  ]
  name "ceiling"
  physics Physics { density 2000 }
}

# Wall 1 (left)
Solid {
  translation -25 0 5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.4 0.4 0.45
        metallic 0
        roughness 0.8
      }
      geometry Box { size 0.2 40 10 }
    }
  ]
  name "wall_left"
  physics Physics { density 2000 }
}

# Wall 2 (right)
Solid {
  translation 25 0 5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.4 0.4 0.45
        metallic 0
        roughness 0.8
      }
      geometry Box { size 0.2 40 10 }
    }
  ]
  name "wall_right"
  physics Physics { density 2000 }
}

